# ─────────────────────────────────────────────────────────────
# AI Log Analyzer — Environment Variables
# ─────────────────────────────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Paste your key below (keep the quotes out)
#   3. NEVER commit .env to Git — it's already in .gitignore
#
# HOW TO GET A FREE GEMINI API KEY (no card needed):
#   1. Go to  https://aistudio.google.com
#   2. Sign in with any Google account
#   3. Click "Get API Key" → "Create API key in new project"
#   4. Copy the key and paste it below
#
# FREE TIER LIMITS:
#   - 15 requests per minute
#   - 1,500 requests per day
#   - Completely free, no billing required
# ─────────────────────────────────────────────────────────────

GEMINI_API_KEY=YOUR-API-KEY

# Flask secret key (can be any random string)
FLASK_SECRET_KEY=change-this-to-anything-random

FLASK_ENV=development
